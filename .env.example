# Clerk Authentication
# Get these from https://dashboard.clerk.com → API Keys
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_your_publishable_key_here
CLERK_SECRET_KEY=sk_test_your_secret_key_here

# Optional: Custom Clerk URLs (these are the defaults)
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/dashboard

# Supabase
# Get these from https://supabase.com/dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Database (for Drizzle ORM)
# Get from Supabase Dashboard → Settings → Database → Connection string
# Use direct connection (port 5432) for migrations
# URL-encode special characters in password (e.g., @ becomes %40, $ becomes %24)
DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@db.YOUR_PROJECT_REF.supabase.co:5432/postgres

# Stripe Payments (optional - required for payment features)
# Get from https://dashboard.stripe.com → Developers → API keys
STRIPE_SECRET_KEY=sk_test_your_secret_key_here
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your_publishable_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here

# Secure signed cancel tokens for checkout cancel redirect
# Set a strong random string in every environment (prod, staging, dev)
CANCEL_TOKEN_SECRET=your_cancel_token_hmac_secret

# Email (Resend) - Transactional notifications
# Required in production (in dev, emails will be skipped if missing)
# Get from https://resend.com → API Keys
RESEND_API_KEY=re_your_api_key_here
EMAIL_FROM="Huckleberry Mentorships <noreply@yourdomain.com>"
# Optional
EMAIL_REPLY_TO="Support <support@yourdomain.com>"
# Use Resend hosted Templates (recommended)
# 1) Create and Publish a Template in Resend Dashboard → Templates
# 2) Copy the Template ID (e.g., tmpl_xxxxx or a slug/UUID)
# 3) Enable templates and set the template ID below
EMAIL_USE_TEMPLATES=true
RESEND_TEMPLATE_ID_PURCHASE_ONBOARDING=tmpl_your_purchase_onboarding_template_id
RESEND_TEMPLATE_ID_INSTRUCTOR_PURCHASE=tmpl_your_instructor_notification_template_id
RESEND_TEMPLATE_ID_ADMIN_PURCHASE=tmpl_your_admin_notification_template_id

# App base URL (used to generate links inside emails)
# Either NEXT_PUBLIC_URL or VERCEL_URL must be set in production
# VERCEL_URL is automatically set by Vercel, so you only need NEXT_PUBLIC_URL for custom domains
NEXT_PUBLIC_URL=https://yourdomain.com

# Web App URL (used by marketing app to proxy API requests)
# Marketing app uses this to call web app's waitlist/contacts APIs
# Server-only environment variable (not NEXT_PUBLIC_)
WEB_APP_URL=https://yourdomain.com

# Axiom Observability (optional - for logging and monitoring)
# Get from https://axiom.co → Settings → API Tokens
AXIOM_TOKEN=your_axiom_token_here
AXIOM_DATASET=your_dataset_name_here

# Trigger.dev (for background tasks)
# Get from https://trigger.dev → Settings → API Keys
TRIGGER_API_KEY=tr_your_api_key_here
NEXT_PUBLIC_TRIGGER_PROJECT_REF=proj_your_project_ref_here

# Convex HTTP Key (for Inngest/Trigger.dev to call Convex HTTP endpoints)
# Get from Convex dashboard → Settings → API Keys
CONVEX_HTTP_KEY=your_convex_http_key_here

# Convex Deployment URL (for Inngest to call Convex HTTP endpoints)
# Get from Convex dashboard → Settings → Deployment URLs (use production URL in prod)
CONVEX_URL=https://your-convex-deployment.convex.cloud

# Discord Integration (optional)
# Provide bot token and guild ID to enable role assignment and DM notifications
# Prefer DISCORD_STUDENT_ROLE_NAME; DISCORD_MENTEE_ROLE_NAME is deprecated and used only as a fallback
DISCORD_BOT_TOKEN=your_discord_bot_token_here
DISCORD_GUILD_ID=your_discord_guild_id_here
DISCORD_STUDENT_ROLE_NAME=Student
# Legacy compatibility (deprecated):
# DISCORD_MENTEE_ROLE_NAME=Student

# Daily.co (video calling)
# Get these from https://dashboard.daily.co → Developers
# Recording requires a paid Daily.co plan; free tier rejects the
# `enable_recording: "cloud"` call silently.
DAILY_API_KEY=<COPY_FROM_VERCEL>
DAILY_API_URL=https://api.daily.co/v1
NEXT_PUBLIC_DAILY_DOMAIN=huckleberryartinc.daily.co
# Webhook secret. Daily generates this as base64 (NOT hex). Paste
# into Daily's room webhook config AND Vercel as DAILY_WEBHOOK_SECRET.
DAILY_WEBHOOK_SECRET=<BASE64_SECRET_FROM_DAILY_DASHBOARD>

# Backblaze B2 (recordings + instructor uploads + workspace exports)
# Application key scoped to the `instructor-uploads` bucket. The
# video-recording transfer task needs read+write; exports need read.
B2_KEY_ID=<COPY_FROM_VERCEL>
B2_APPLICATION_KEY=<COPY_FROM_VERCEL>
B2_BUCKET_NAME=instructor-uploads
B2_REGION=us-west-002
B2_ENDPOINT=https://s3.us-west-002.backblazeb2.com

# Trigger.dev → Convex recording-transfer callback secret.
# Used by src/trigger/recording-transfer.ts to authenticate the
# /recording-transfer/* callbacks. Set identically on both sides.
# Generate with: openssl rand -hex 32
TRIGGER_CONVEX_CALLBACK_SECRET=<GENERATE_WITH_openssl_rand_-hex_32>
