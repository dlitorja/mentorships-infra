{
  "compilerOptions": {
    "baseUrl": ".",
    "target": "ES2017",
    "lib": [
      "dom",
      "dom.iterable",
      "esnext"
    ],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "incremental": true,
    "plugins": [
      {
        "name": "next"
      }
    ],
    "paths": {
      "@/*": [
        "./*"
      ],
      "@/convex/_generated/*": [
        "../../convex/_generated/*"
      ],
      "@mentorships/db": [
        "../../packages/db/src"
      ],
      "@mentorships/payments": [
        "../../packages/payments/src"
      ],
      "@mentorships/schemas": [
        "../../packages/schemas/src"
      ],
      "@mentorships/ui": [
        "../../packages/ui/src"
      ],
      "@mentorships/emails": [
        "../../packages/emails/src"
      ],
      "@mentorships/emails/*": [
        "../../packages/emails/src/*"
      ],
      "@/trigger": [
        "../../src/trigger"
      ],
      "@/trigger/*": [
        "../../src/trigger/*"
      ]
    }
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts",
    ".next/dev/types/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    "../../convex/**/*.ts",
    "../../packages/db/**/*.ts"
  ]
}
