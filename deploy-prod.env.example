# Production Convex deployment for `npx convex deploy`
# Usage: npx convex deploy --env-file deploy-prod.env
#
# For CI/CD: Set CONVEX_DEPLOY_KEY in your CI secrets, not in this file.
# Example: In GitHub Actions, add CONVEX_DEPLOY_KEY as a secret.

CONVEX_DEPLOYMENT=your-production-deployment-name

# Production deploy key (starts with prod:)
# Set via CI secrets or environment, NOT in this file
# CONVEX_DEPLOY_KEY=prod:your-token-here